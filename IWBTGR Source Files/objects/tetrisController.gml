#define Step_0
/*"/*'/**//* YYD ACTION
lib_id=1
action_id=603
applies_to=self
*/
if (!instance_exists(player)) exit
if (!inside_view()) {
    if (timer > 0) {
        play_music("kirby")
        instance_create(763,64,block)
    }
    instance_destroy()
    exit
}
if (timer >= 0) {
    move_tetrimino(movex[timer],movey[timer])
    if ((movex[timer]!=0) && time_since_last_move<=0) {
        play_sound("move")
        time_since_last_move=10
    }
    if (rotcw[timer]) rotate_tetrimino(true)
    if (rotccw[timer]) rotate_tetrimino(false)
    if (nexts[timer]) {create_tetrimino(next) next=nexts[timer]}
    if (clear[timer]) clear_tetris_rows(clear[timer])
}
// cap the timer because arrays only go up to 32k
if (timer<3000) {
    timer+=1
    time_since_last_move-=1
}
#define Draw_0
/*"/*'/**//* YYD ACTION
lib_id=1
action_id=603
applies_to=self
*/
switch next {
case l: {
    draw_sprite(sprTetrisBlock,l-1,657,201)
    draw_sprite(sprTetrisBlock,l-1,657,217)
    draw_sprite(sprTetrisBlock,l-1,657,233)
    draw_sprite(sprTetrisBlock,l-1,673,233)
} break
case z: {
    draw_sprite(sprTetrisBlock,z-1,673,201)
    draw_sprite(sprTetrisBlock,z-1,673,217)
    draw_sprite(sprTetrisBlock,z-1,657,217)
    draw_sprite(sprTetrisBlock,z-1,657,233)
} break
case t: {
    draw_sprite(sprTetrisBlock,t-1,657,201)
    draw_sprite(sprTetrisBlock,t-1,657,217)
    draw_sprite(sprTetrisBlock,t-1,657,233)
    draw_sprite(sprTetrisBlock,t-1,673,217)
} break
case j: {
    draw_sprite(sprTetrisBlock,j-1,673,201)
    draw_sprite(sprTetrisBlock,j-1,673,217)
    draw_sprite(sprTetrisBlock,j-1,657,233)
    draw_sprite(sprTetrisBlock,j-1,673,233)
} break
case i: {
    draw_sprite(sprTetrisBlock,i-1,665,193)
    draw_sprite(sprTetrisBlock,i-1,665,209)
    draw_sprite(sprTetrisBlock,i-1,665,225)
    draw_sprite(sprTetrisBlock,i-1,665,241)
} break
case o: {
    draw_sprite(sprTetrisBlock,o-1,657,209)
    draw_sprite(sprTetrisBlock,o-1,673,209)
    draw_sprite(sprTetrisBlock,o-1,657,225)
    draw_sprite(sprTetrisBlock,o-1,673,225)
} break
case s: {
    draw_sprite(sprTetrisBlock,z-1,657,201)
    draw_sprite(sprTetrisBlock,z-1,657,217)
    draw_sprite(sprTetrisBlock,z-1,673,217)
    draw_sprite(sprTetrisBlock,z-1,673,233)
} break
case pill: {
    draw_sprite_ext(sprKillPill,0,671,233,2,2,0,c_white,1)
} break
}

draw_set_font(fNes)
// big boxes
draw_text(32+4,32+8,"LEVEL: 3")
draw_text(32+4,64+8,"LINES: "+string(lines))
draw_text(608-32+4,352+8,"SCORE:"+format(scor,5))

// little boxes
draw_text(128+3,151+8,counts[l])
draw_text(128+3,224+8,counts[j])
draw_text(128+3,288+8,counts[z])
draw_text(128+3,352+8,counts[s])
draw_text(128+3,416+8,counts[o])
draw_text(128+3,480+8,counts[t])
draw_text(128+3,540+8,counts[i])
